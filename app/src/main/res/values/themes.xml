<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- ===================================================================
         Thème de base GeoEvent — Material 3, violet clair, bords arrondis
         =================================================================== -->
    <style name="Base.Theme.GeoEventKotlin" parent="Theme.Material3.Light.NoActionBar">

        <!-- Couleurs primaires -->
        <item name="colorPrimary">@color/md_primary</item>
        <item name="colorOnPrimary">@color/md_on_primary</item>
        <item name="colorPrimaryContainer">@color/md_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/md_on_primary_container</item>

        <!-- Couleurs secondaires -->
        <item name="colorSecondary">@color/md_secondary</item>
        <item name="colorOnSecondary">@color/md_on_secondary</item>
        <item name="colorSecondaryContainer">@color/md_secondary_container</item>
        <item name="colorOnSecondaryContainer">@color/md_on_secondary_container</item>

        <!-- Surfaces et fonds -->
        <item name="android:colorBackground">@color/md_background</item>
        <item name="colorSurface">@color/md_surface</item>
        <item name="colorOnSurface">@color/md_on_surface</item>
        <item name="colorSurfaceVariant">@color/md_surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/md_on_surface_variant</item>
        <item name="colorOutline">@color/md_outline</item>
        <item name="colorOutlineVariant">@color/md_outline_variant</item>

        <!-- Erreur -->
        <item name="colorError">@color/md_error</item>
        <item name="colorOnError">@color/md_on_error</item>
        <item name="colorErrorContainer">@color/md_error_container</item>
        <item name="colorOnErrorContainer">@color/md_on_error_container</item>

        <!-- Arrondis globaux (appliqués automatiquement aux composants Material) -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.GeoEvent.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.GeoEvent.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.GeoEvent.Large</item>

        <!-- Styles de composants globaux -->
        <item name="materialButtonStyle">@style/Widget.GeoEvent.Button</item>
        <item name="textInputStyle">@style/Widget.GeoEvent.TextInputLayout</item>
        <item name="materialCardViewStyle">@style/Widget.GeoEvent.CardView</item>
        <item name="toolbarStyle">@style/Widget.GeoEvent.Toolbar</item>
    </style>

    <style name="Theme.GeoEventKotlin" parent="Base.Theme.GeoEventKotlin" />

    <!-- ===================================================================
         Formes arrondies
         =================================================================== -->

    <style name="ShapeAppearance.GeoEvent.Small" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

    <style name="ShapeAppearance.GeoEvent.Medium" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <style name="ShapeAppearance.GeoEvent.Large" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">28dp</item>
    </style>

    <!-- ===================================================================
         Composants personnalisés
         =================================================================== -->

    <!-- Bouton : insets réduits pour plus de hauteur, coins 12dp -->
    <style name="Widget.GeoEvent.Button" parent="Widget.Material3.Button">
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:textSize">15sp</item>
        <item name="android:letterSpacing">0.03</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <!-- Champ de saisie : OutlinedBox avec coins 12dp -->
    <style name="Widget.GeoEvent.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>

    <!-- Carte Material : coins 16dp, élévation légère -->
    <style name="Widget.GeoEvent.CardView" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardMaxElevation">6dp</item>
    </style>

    <!-- Toolbar : sans élévation (séparateur géré par AppBarLayout) -->
    <style name="Widget.GeoEvent.Toolbar" parent="Widget.Material3.Toolbar.Surface">
        <item name="android:elevation">0dp</item>
    </style>

    <!-- Typographie toolbar -->
    <style name="TextAppearance.GeoEvent.Toolbar" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

</resources>
